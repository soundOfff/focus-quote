# Staging environment template for the FocusQuote backend.
#
# Copy to `.env.staging` (never commit it). Load with
# `tsx --env-file=./.env.staging src/index.ts` or your deployment platform's
# secret manager.

NODE_ENV=production
PORT=3000

# --- Turso staging database ---
# Create with: turso db create focusquote-staging
# Token: turso db tokens create focusquote-staging
DATABASE_URL=libsql://focusquote-staging-<org>.turso.io
DATABASE_AUTH_TOKEN=replace-with-staging-token

# --- Better Auth ---
# Different from prod. Rotate independently.
BETTER_AUTH_SECRET=replace-with-32-byte-base64
BETTER_AUTH_URL=https://focusquote-staging.example.com

# --- Extension origin (chrome-extension://<staging-id>) ---
EXTENSION_ORIGIN=chrome-extension://replace-with-staging-extension-id

# --- OAuth (point at staging callback URLs in Google Console) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=staging@focusquote.example.com

# --- LLM provider ---
LLM_PROVIDER=openrouter
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# --- Secrets at-rest encryption (REQUIRED in staging/prod) ---
# Distinct from production.
SECRETS_ENCRYPTION_KEY=replace-with-staging-32-byte-base64
