{
  "name": "@focus-quote/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "start": "tsx --env-file-if-exists=.env src/index.ts",
    "start:staging": "tsx --env-file-if-exists=.env.staging src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file-if-exists=.env src/db/migrate.ts",
    "db:migrate:staging": "tsx --env-file-if-exists=.env.staging src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:push:staging": "DOTENV_CONFIG_PATH=.env.staging drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@focus-quote/shared": "*",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.1",
    "@libsql/client": "^0.14.0",
    "better-auth": "^1.1.4",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.13",
    "openai": "^6.37.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
