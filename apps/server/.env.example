# --- Server ---
NODE_ENV=development
PORT=3000

# --- Database (libSQL / Turso) ---
# For local dev, leave defaults to use a file-backed SQLite DB.
# For production, set Turso URL + token.
DATABASE_URL=file:./data.db
DATABASE_AUTH_TOKEN=

# --- Better Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# --- Extension origin (CORS allowlist) ---
# Format: chrome-extension://<EXTENSION_ID>
EXTENSION_ORIGIN=chrome-extension://INVALID

# --- Google OAuth (optional in dev) ---
# Create a client at https://console.cloud.google.com → Credentials → OAuth 2.0
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (Resend) ---
# Optional in dev — leave RESEND_API_KEY empty to log magic links to stdout.
RESEND_API_KEY=
RESEND_FROM_EMAIL=focusquote@example.com
