# --- Server ---
NODE_ENV=development
PORT=3000

# --- Database (libSQL / Turso) ---
# For local dev, leave defaults to use a file-backed SQLite DB.
# For production, set Turso URL + token.
DATABASE_URL=file:./data.db
DATABASE_AUTH_TOKEN=

# --- Better Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# --- Extension origin (CORS allowlist) ---
# Format: chrome-extension://<EXTENSION_ID>
EXTENSION_ORIGIN=chrome-extension://INVALID

# --- Google OAuth (optional in dev) ---
# Create a client at https://console.cloud.google.com → Credentials → OAuth 2.0
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (Resend) ---
# Optional in dev — leave RESEND_API_KEY empty to log magic links to stdout.
RESEND_API_KEY=
RESEND_FROM_EMAIL=focusquote@example.com

# --- LLM provider ---
# Optional. "anthropic" or "openrouter". If unset, auto: prefers Anthropic when
# both keys are present, else falls back to OpenRouter, else no-op.
LLM_PROVIDER=

# --- Anthropic (server-side AI for session URL analysis) ---
# Optional in dev — endpoints degrade to no-op classification if missing.
ANTHROPIC_API_KEY=

# --- OpenRouter (OpenAI-compatible gateway, supports free models) ---
# Optional. Sign up at https://openrouter.ai for a key. Free models have
# the :free suffix (rate-limited). Override the model with OPENROUTER_MODEL.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# --- Secrets at-rest encryption ---
# Required to store user-provided secrets (e.g. user-managed OpenRouter
# API keys) in the `user_secrets` table. Must decode to 32 raw bytes.
# Generate with: openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=
